# Application
APP_NAME=Agentic System
DEBUG=false
VERSION=1.0.0

# API
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# LLM Service
LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# Vector Database
VECTOR_PROVIDER=pinecone
VECTOR_API_KEY=your_vector_api_key
VECTOR_INDEX_NAME=agent-knowledge
VECTOR_DIMENSION=1536

# Redis
REDIS_URL=redis://localhost:6379

# Pulse — Core
GEMINI_API_KEY=your_gemini_api_key
NEWS_API_KEY=your_newsapi_org_key

# Pulse — Email delivery (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
DIGEST_FROM_EMAIL=pulse@yourdomain.com   # must be verified in Resend dashboard
DIGEST_TO_EMAIL=you@example.com